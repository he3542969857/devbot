# 复制为 .env 并填入真实值(.env 已被 .gitignore 忽略,勿提交)
SILICONFLOW_API_KEY=YOUR_SILICONFLOW_API_KEY
DEVPLATFORM_PG_DSN=host=127.0.0.1 port=5432 dbname=devplatform user=codedoc password=CHANGE_ME_PG_PASSWORD
CODEDOC_PG_DSN=host=127.0.0.1 port=5432 dbname=codedoc user=codedoc password=CHANGE_ME_PG_PASSWORD
# 接 CodeDoc 的内部 server-to-server key(与 CodeDoc 端一致)
CODEDOC_INTERNAL_KEY=CHANGE_ME_INTERNAL_KEY
# 接 CodeDoc 模式:http(真检索) / mock(本地假数据)
DEVBOT_CODEDOC_MODE=http
# GitHub webhook 校验密钥
GITHUB_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET
